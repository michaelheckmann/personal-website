---
import { thumbHashToDataURL } from "thumbhash";

interface Props {
  id: string;
  title: string;
  imageUrl: string;
  thumbhash: string;
  width: number;
  height: number;
  description?: string;
  index: number;
}

const { title, imageUrl, thumbhash, width, height, description, index } =
  Astro.props;

const aspectRatio = width / height;

function base64ToUint8Array(base64: string): Uint8Array {
  return Uint8Array.from(atob(base64), (char) => char.charCodeAt(0));
}

const placeholderDataUrl = thumbHashToDataURL(base64ToUint8Array(thumbhash));
const eager = index < 6;
---

<button
  type="button"
  class="group relative block w-full cursor-zoom-in break-inside-avoid overflow-hidden rounded-lg bg-zinc-800/50 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-zinc-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
  style={{ aspectRatio }}
  data-gallery-item
  data-index={index}
  aria-label={`View ${title}`}
>
  <!-- Thumbhash placeholder -->
  <img
    src={placeholderDataUrl}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 h-full w-full object-cover transition-opacity duration-500"
    data-placeholder
    width="32"
    height="32"
  />

  <!-- Actual image -->
  <img
    src={eager ? imageUrl : undefined}
    data-src={eager ? undefined : imageUrl}
    alt={title}
    width={width}
    height={height}
    decoding="async"
    loading={eager ? "eager" : undefined}
    fetchpriority={eager ? "high" : undefined}
    class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500"
    data-image
  />

  <!-- Hover overlay with title -->
  <div
    class="absolute inset-0 flex items-end bg-gradient-to-t from-zinc-950 p-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
  >
    <div class="space-y-1">
      <h3 class="text-sm font-medium text-zinc-100">{title}</h3>
      {
        description && (
          <p class="line-clamp-2 text-xs text-zinc-300">{description}</p>
        )
      }
    </div>
  </div>
</button>

<script>
  let imageObserver: IntersectionObserver | null = null;

  function loadImage(image: HTMLImageElement) {
    if (image.dataset.loaded === "true") return;

    const src = image.dataset.src;
    if (!src) return;

    image.dataset.loaded = "true";
    image.src = src;
  }

  function getImageObserver() {
    if (!("IntersectionObserver" in window)) return null;
    if (imageObserver) return imageObserver;

    imageObserver = new IntersectionObserver(
      (entries, observer) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const image = entry.target as HTMLImageElement;
          loadImage(image);
          observer.unobserve(image);
        });
      },
      {
        rootMargin: "300px 0px",
      },
    );

    return imageObserver;
  }

  function initGalleryItems() {
    const items = document.querySelectorAll("[data-gallery-item]");
    const observer = getImageObserver();

    items.forEach((item) => {
      const placeholder = item.querySelector(
        "[data-placeholder]",
      ) as HTMLImageElement | null;
      const image = item.querySelector(
        "[data-image]",
      ) as HTMLImageElement | null;

      if (!placeholder || !image) return;

      if (image.dataset.bound !== "true") {
        image.dataset.bound = "true";
        image.addEventListener(
          "load",
          () => handleImageLoad(image, placeholder),
          { once: true },
        );
      }

      if (image.complete && image.naturalWidth > 0) {
        handleImageLoad(image, placeholder);
        return;
      }

      if (!image.dataset.src) {
        return;
      }

      if (!observer) {
        loadImage(image);
        return;
      }

      observer.observe(image);
    });
  }

  function handleImageLoad(
    image: HTMLImageElement,
    placeholder: HTMLImageElement,
  ) {
    image.style.opacity = "1";
    placeholder.style.opacity = "0";
  }

  initGalleryItems();

  document.addEventListener("astro:after-swap", initGalleryItems);
</script>
